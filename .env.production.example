APP_NAME="4est.info"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://www.4est.info

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mariadb
DB_HOST=fleet-db-1
DB_PORT=3306
DB_DATABASE=4est_presentation
DB_USERNAME=4est_presentation
DB_PASSWORD=CHANGE_ME

# Mail (Resend, same as fleet)
MAIL_MAILER=resend
RESEND_API_KEY=CHANGE_ME
MAIL_FROM_ADDRESS=noreply@4est.info
MAIL_FROM_NAME="4est.info"

# Cache + session
CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database

# Localization
APP_LOCALE=ro
APP_FALLBACK_LOCALE=en
