# Nginx image with Laravel public/ pre-copied so try_files works
FROM 4est-presentation:latest AS app_source

FROM nginx:alpine
COPY --from=app_source /var/www/public /var/www/public
COPY docker/nginx/default.conf /etc/nginx/conf.d/default.conf

# Symlink public/storage → storage/app/public so user-uploaded files are served
# (storage volume is shared with the app container)
RUN ln -s /var/www/storage/app/public /var/www/public/storage
